@page "/rendelesek"

@using GameStore.Frontend.Clients
@using GameStore.Frontend.Models

@inject RendelesekClient RendelesekClient
@inject VasarlokClient VasarlokClient
@inject TermekekClient TermekekClient

@attribute [StreamRendering]

<PageTitle>Rendelesek</PageTitle>
<style>
  

  body {
    background-image: url('/veglegeshatter.jpg');
    background-size: cover;
    background-position: center;
    min-height: 100vh;
    background-repeat: no-repeat;
  }

  text {
    color: white;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);
  }
  .table 
{
    background-color: rgba(0, 0, 0, 0.2) !important; 
    color: white !important;
    border-collapse: collapse !important;
    border: 2px solid #fff !important; 
    border-collapse: collapse; 
    
}


/* Fejléc (thead) áttetsző sötét háttér */
.table-dark td 
{
    background-color: rgba(156, 139, 139, 0.2) !important; 
    color: white !important;
    border-collapse: collapse !important;

}

.table-dark th
{
    background-color: rgba(156, 139, 139, 0.2) !important; 
    color: white !important;
    border-collapse: collapse !important;
    

}

.table-row-custom td
{
    background-color: rgba(156, 139, 139, 0.2) !important; 
    color: white !important;
    border-collapse: collapse !important;
  
}


/* Fejléc cellák */
thead th 
{
    border: 2px solid #fff; 
    color: #fff; 
    background-color: rgba(0, 0, 0, 0.5) !important; /* Átlátszóbb háttér */
    padding: 10px; 
    text-align: left;
    
}

/* Tartalom cellák */
tbody td 
{
    border: 2px solid #fff; 
    color: #fff; 
    background-color: rgba(0, 0, 0, 0.5) !important; /* Átlátszóbb háttér */
    padding: 10px;
    text-align: left;
    
}



.table-bordered 
{
    border-color: white !important;
    
}

.table-bordered th,
.table-bordered td 
{
    border: 2px solid white !important;
    
}
.id {
    width: 50px;
    text-align: center;
    font-weight: bold;
}
.szia {
    font-size: 1.9em;
    text-shadow: 2px 2px 4px rgba(0, 162, 255, 0.47);
    background-color: rgba(0, 4, 255, 0.5);
    text-align: center;
}



  </style>

<div class="mt-2">
  <a class="btn btn-primary" role="button" href="/editrendeles">Új Rendelés</a>
</div>

@if (rendelesek is null || vasarlok is null || termekek is null)
{
  <p><em>Loading...</em></p>
}
else
{
  <table class=" table table-striped table-bordered table-hover mt-3">
    <thead class="table-dark">
      <th>Rendelés ID</th>
      <th>Vásárló Neve</th>
      <th>Termék/ID</th>
      <th>Darabszám</th>
      <th>Rendelés dátuma</th>
      <th>fizetési mód</th>
      <th>Szállítási mód</th>
      <th></th>
    </thead>
    <tbody>
      @foreach (RendelesekSummary rendeles in rendelesek)
      {
        <tr>
          <td class="szia">@rendeles.Rendelesek_ID</td>
          <td>@vasarlok.FirstOrDefault(vasarlo => vasarlo.Vasarlo_ID == rendeles.Vasarlo_ID)?.Nev</td>
          <td>@termekek.FirstOrDefault(termek => termek.Jatek_ID == rendeles.termek_ID)?.Cim</td>
          <td>@rendeles.Darabszam</td>
          <td>@rendeles.Rendeles_datuma</td>
          <td>@rendeles.fizetesi_mod</td>
          <td>@rendeles.szallitasi_mod</td>
          <td>
            <div class="d-flex">
              <a class="btn btn-primary me-2" role="button" href="@RendelesUrl(rendeles.Rendelesek_ID)">
                <i class="bi bi-pencil"></i>
              </a>
              <button  class="btn btn-danger" data-bs-toggle="modal" data-bs-target="@GetDeleteModalId(rendeles)"><i
                class="bi bi-x-lg"></i></button>
              
              </div>
              <DeleteRendeles Rendeles="@rendeles" />
            </td>
          </tr>
        }
      </tbody>
    </table>
    @if (vasarlok.Length == 0)
    {
      <p>Nincs adat!</p>
    }
  }
  
@code {
  private RendelesekSummary[]? rendelesek;
  private VasarlokSummary[]? vasarlok;
  private TermekekSummary[]? termekek;

  
  protected override async Task OnInitializedAsync()
  {
    rendelesek = await RendelesekClient.GetRendelesekAsync();
    vasarlok = await VasarlokClient.GetVasarlokAsync();
    termekek = await TermekekClient.GetTermekekAsync();
  }

  private static string RendelesUrl(int id) => $"/editrendeles/{id}";

  private string GetDeleteModalId(RendelesekSummary rendeles)
  {
    return $"#{DeleteRendeles.GetModalId(rendeles)}";
  }
}