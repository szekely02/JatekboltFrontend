@page "/termekek"

@using GameStore.Frontend.Clients
@using GameStore.Frontend.Models

@inject TermekekClient Client

@attribute [StreamRendering]

<PageTitle>Játék katalógus</PageTitle>
<style>
 


  body {
    background-image: url('/veglegeshatter.jpg');
    background-size: cover;
    background-position: center;
    min-height: 100vh;
    background-repeat: no-repeat;
  }

  text {
    color: white;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);
    text-align: center;
  }
  .table 
{
    background-color: rgba(0, 0, 0, 0.2) !important; 
    color: white !important;
    border-collapse: collapse !important;
    border: 2px solid #fff !important; 
    border-collapse: collapse; 
    text-align: center;
    
}


/* Fejléc (thead) áttetsző sötét háttér */
.table-dark td 
{
    background-color: rgba(156, 139, 139, 0.2) !important; 
    color: white !important;
    border-collapse: collapse !important;

}

.table-dark th
{
    background-color: rgba(156, 139, 139, 0.2) !important; 
    color: white !important;
    border-collapse: collapse !important;
    f

}

.table-row-custom td
{
    background-color: rgba(156, 139, 139, 0.2) !important; 
    color: white !important;
    border-collapse: collapse !important;
  
}


/* Fejléc cellák */
thead th 
{
    border: 2px solid #fff; 
    color: #fff; 
    background-color: rgba(0, 0, 0, 0.5) !important; /* Átlátszóbb háttér */
    padding: 10px; 
    text-align: center;
    
}

/* Tartalom cellák */
tbody td 
{
    border: 2px solid #fff; 
    color: #fff; 
    background-color: rgba(0, 0, 0, 0.5) !important; /* Átlátszóbb háttér */
    padding: 10px;
    text-align: center;
    
}



.table-bordered 
{
    border-color: white !important;
    
}

.table-bordered th,
.table-bordered td 
{
    border: 2px solid white !important;
    
}
.id {
    width: 50px;
    text-align: center;
    font-weight: bold;
}
.szia {
    font-size: 1.9em;
    text-shadow: 2px 2px 4px rgba(0, 162, 255, 0.47);
    background-color: rgba(0, 4, 255, 0.5);
}


</style>

<div class="mt-2">
  <a class="btn btn-primary" role="button" href="/editgame">Új játék</a>
</div>

@if (termekek is null)
{
  <p><em>Loading...</em></p>
}
else
{
  <table class="table table-striped table-bordered table-hover mt-3 ">
    <thead class="table-dark">
      <th class="id ">Id</th>
      <th>Cím</th>
      <th>Platform</th>
      <th>Kiadó</th>
      <th>Műfaj</th>
      <th>megjelenési dátum</th>
      <th>Korhatár</th>
      <th>Leírás</th>
      <th class="text-end">Ár</th>
      <th>Akciós ár</th>
      <th>Raktarkészlet</th>
      <th></th>
    </thead>
    <tbody>
      @foreach (var termek in termekek)
      {
        <tr>
          <td class="id szia">@termek.Jatek_ID</td>
          <td>@termek.Cim</td>
          <td>@termek.Platform</td>
          <td>@termek.Kiado</td>
          <td>@termek.Mufaj</td>
          <td>@termek.megjelenesi_datum.ToShortDateString()</td>
          <td>@termek.korhatar_besorolas</td>
          <td>@termek.leiras</td>
          <td class="text-end">@termek.ar.ToString("C2")</td>
          <td class="text-end">@termek.akcios_ar.ToString("C2")</td>
          <td class="text-end">@termek.Raktarkeszlet</td>

          <td>
            <div class="d-flex flex-nowrap">
              <a class="btn btn-primary me-2" role="button" href="@GameUrl(termek.Jatek_ID)">
                <i class="bi bi-pencil"></i>
              </a>
              <button class="btn btn-danger me-2" data-bs-toggle="modal" data-bs-target="@GetDeleteModalId(termek)">
                <i class="bi bi-x-lg"></i>
              </button>
              <a class="btn btn-success" role="button" href="@RendelesUrl(termek.Jatek_ID)">
                <i class="bi bi-cart-plus"></i>
              </a>
            </div>
            <DeleteGame Termek="@termek" />
          </td>

        </tr>
      }
    </tbody>
  </table>
}

@code {
  private TermekekSummary[]? termekek;
  protected override async Task OnInitializedAsync()
  {
    termekek = await Client.GetTermekekAsync();
  }

  private static string GameUrl(int id) => $"/editgame/{id}";

  private static string RendelesUrl(int id) => $"/editrendeles?termekId={id}";

  private string GetDeleteModalId(TermekekSummary termek)
  {
    return $"#{DeleteGame.GetModalId(termek)}";
  }
}
