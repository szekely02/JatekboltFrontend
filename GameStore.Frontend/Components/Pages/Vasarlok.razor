@page "/vasarlok"

@using GameStore.Frontend.Clients
@using GameStore.Frontend.Models

@inject VasarlokClient Client

@attribute [StreamRendering]

<PageTitle>Vásárlók katalógus</PageTitle>
<style>
  

  body {
    background-image: url('/hatter1.jpg');
    background-size: cover;
    background-position: center;
    min-height: 100vh;
    background-repeat: no-repeat;
  }

  text {
    color: white;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);
  }
  .table 
{
    background-color: rgba(0, 0, 0, 0.2) !important; 
    color: white !important;
    border-collapse: collapse !important;
    border: 2px solid #fff !important; 
    border-collapse: collapse; 
    
}


/* Fejléc (thead) áttetsző sötét háttér */
.table-dark td 
{
    background-color: rgba(156, 139, 139, 0.2) !important; 
    color: white !important;
    border-collapse: collapse !important;

}

.table-dark th
{
    background-color: rgba(156, 139, 139, 0.2) !important; 
    color: white !important;
    border-collapse: collapse !important;
    f

}

.table-row-custom td
{
    background-color: rgba(156, 139, 139, 0.2) !important; 
    color: white !important;
    border-collapse: collapse !important;
  
}


/* Fejléc cellák */
thead th 
{
    border: 2px solid #fff; 
    color: #fff; 
    background-color: rgba(0, 0, 0, 0.5) !important; /* Átlátszóbb háttér */
    padding: 10px; 
    text-align: left;
    
}

/* Tartalom cellák */
tbody td 
{
    border: 2px solid #fff; 
    color: #fff; 
    background-color: rgba(0, 0, 0, 0.5) !important; /* Átlátszóbb háttér */
    padding: 10px;
    text-align: left;
    
}



.table-bordered 
{
    border-color: white !important;
    
}

.table-bordered th,
.table-bordered td 
{
    border: 2px solid white !important;
    
}


  </style>
<div class="mt-2">
  <a class="btn btn-primary" role="button" href="/editVasarlo">Új Vásárló</a>
</div>

@if (vasarlok is null)
{
  <p><em>Betöltés...</em></p>
}
else
{
  <table class="table table-striped table-bordered table-hover mt-3">
    <thead class="table-dark">
      <th>Név</th>
      <th>Email</th>
      <th>Telefonszám</th>
      <th>Szállítási cím</th>
      <th></th>
    </thead>
    <tbody>
      @foreach (VasarlokSummary vasarlo in vasarlok)
      {
        <tr>
          <td>@vasarlo.Nev</td>
          <td>@vasarlo.Email</td>
          <td>@vasarlo.telefonszam</td>
          <td>@vasarlo.szallitasi_cim</td>
          <td>
            <div class="d-flex">
              <a class="btn btn-primary me-2" role="button" href="@VasarloUrl(vasarlo.Vasarlo_ID)">
                <i class="bi bi-pencil"></i>
              </a>
              <button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="@GetDeleteModalId(vasarlo)">
                <i class="bi bi-x-lg"></i>
              </button>
            </div>
            <DeleteVasarlo Vasarlo="@vasarlo" />
          </td>
        </tr>
      }
    </tbody>
  </table>
  @if (vasarlok.Length == 0)
  {
    <p>Nincs adat!</p>
  }
}
  
@code {
  private VasarlokSummary[]? vasarlok;
  protected override async Task OnInitializedAsync()
  {
    vasarlok = await Client.GetVasarlokAsync();
  }

  private static string VasarloUrl(int id) => $"/editvasarlo/{id}";

  private string GetDeleteModalId(VasarlokSummary vasarlo)
  {
    return $"#{DeleteVasarlo.GetModalId(vasarlo)}";
  }
}