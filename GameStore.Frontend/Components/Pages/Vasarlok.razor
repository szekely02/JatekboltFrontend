@page "/vasarlok"

@using GameStore.Frontend.Clients
@using GameStore.Frontend.Models

@inject VasarlokClient Client

@attribute [StreamRendering]

<PageTitle>Vásárlók katalógus</PageTitle>

<div class="mt-2">
  <a class="btn btn-primary" role="button" href="/editVasarlo">Új Vásárló</a>
</div>

@if (vasarlok is null)
{
  <p><em>Betöltés...</em></p>
}
else
{
  <table class="table table-striped table-bordered table-hover mt-3">
    <thead class="table-dark">
      <th>Név</th>
      <th>Email</th>
      <th>Telefonszám</th>
      <th>Szállítási cím</th>
      <th></th>
    </thead>
    <tbody>
      @foreach (VasarlokSummary vasarlo in vasarlok)
      {
        <tr>
          <td>@vasarlo.Nev</td>
          <td>@vasarlo.Email</td>
          <td>@vasarlo.telefonszam</td>
          <td>@vasarlo.szallitasi_cim</td>
          <td>
            <div class="d-flex">
              <a class="btn btn-primary me-2" role="button" href="@VasarloUrl(vasarlo.Vasarlo_ID)">
                <i class="bi bi-pencil"></i>
              </a>
              <button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="@GetDeleteModalId(vasarlo)">
                <i class="bi bi-x-lg"></i>
              </button>
            </div>
            <DeleteVasarlo Vasarlo="@vasarlo" />
          </td>
        </tr>
      }
    </tbody>
  </table>
  @if (vasarlok.Length == 0)
  {
    <p>Nincs adat!</p>
  }
}
  
@code {
  private VasarlokSummary[]? vasarlok;
  protected override async Task OnInitializedAsync()
  {
    vasarlok = await Client.GetVasarlokAsync();
  }

  private static string VasarloUrl(int id) => $"/editvasarlo/{id}";

  private string GetDeleteModalId(VasarlokSummary vasarlo)
  {
    return $"#{DeleteVasarlo.GetModalId(vasarlo)}";
  }
}